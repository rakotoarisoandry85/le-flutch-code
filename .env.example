# ============================================================
#  Le Flutch — Configuration
#  Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── Base de données PostgreSQL ──
DATABASE_URL=postgresql://user:password@host:5432/flutch

# ── Pipedrive ──
PIPEDRIVE_API_TOKEN=colle_ta_cle_ici
BIENS_PIPELINE=Murs
BIENS_STAGE=Commercialisé
ACQUEREURS_PIPELINE=Acquéreurs
ACQUEREURS_STAGE=Matching commercialisé

# ── Serveur ──
PORT=3000
NODE_ENV=development

# Secret de session (OBLIGATOIRE en production — chaîne aléatoire ≥ 32 caractères)
SESSION_SECRET=flutch-secret-change-moi-2024

# Secret webhook Pipedrive (généré automatiquement si absent)
# WEBHOOK_SECRET=

# ── Intégrations (optionnel) ──
BREVO_API_KEY=
RINGOVER_API_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── Auto-sync ──
# Intervalle auto-sync Pipedrive (minutes, 0 = désactivé)
AUTO_SYNC_MINUTES=60

# ── CORS (optionnel, CSV d'origines autorisées) ──
# CORS_ORIGIN=https://example.com
